{
    "configurations": [
        {
            "name": "avr-atmega128",
            "includePath": [
                "${workspaceFolder}/atmega128/**",
                "/usr/local/include/**",
                "/usr/include/**",
                "/usr/lib/avr/**",
                "/usr/lib/gcc/avr/**"
            ],
            "defines": [
                "F_CPU=16000000UL",
                "__AVR__",
                "__AVR_ATmega128__"
            ],
            "compilerPath": "/usr/bin/avr-gcc",
            "compilerArgs": [
                "-mmcu=atmega128",
                "-DF_CPU=16000000UL"
            ],
            "cStandard": "gnu11",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
            "name": "cpp",
            "compileCommands": [
                "${workspaceFolder}/build/compile_commands.json"
            ],
            "includePath": [
                "/usr/include/**"
            ],
            "intelliSenseMode": "gcc-x64",
            "compilerPath": "/usr/bin/arm-none-eabi-gcc",
            "cStandard": "gnu11",
            "cppStandard": "c++17"
        }
    ],
    "version": 4
}